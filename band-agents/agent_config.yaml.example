# Copy this file to agent_config.yaml and fill in your credentials.
# agent_id: the UUID from the agent's settings page in Band.ai
# api_key:  the band_a_... key shown ONCE when you create the agent — store it securely.
#
# Each entry here must be a "Remote Agent" created at app.band.ai/agents
# (New Agent → Remote Agent type). Internal agents do NOT have API keys.

