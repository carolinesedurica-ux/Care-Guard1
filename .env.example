# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FEATHERLESS_API_KEY: API Key for Featherless.ai serverless GPU provider.
FEATHERLESS_API_KEY=""

# AIML_API_KEY: API Key for AI/ML API (aimlapi.com) open-weights provider.
AIML_API_KEY=""

# BAND_AGENT_ID: ID of the Band Agent
BAND_AGENT_ID=""

# BAND_API_KEY: API Key for the Band Agent
BAND_API_KEY=""

# BAND_AGENT_HANDLE: Handle/alias of the Band Agent
BAND_AGENT_HANDLE=""

# BAND_RISK_AGENT_ID: ID of the Risk Analytics Engine
BAND_RISK_AGENT_ID=""

# BAND_RISK_API_KEY: API Key for the Risk Analytics Engine
BAND_RISK_API_KEY=""

# BAND_RISK_HANDLE: Handle/alias of the Risk Analytics Engine
BAND_RISK_HANDLE=""

# BAND_POLICY_AGENT_ID: ID of the Policy Guard Agent
BAND_POLICY_AGENT_ID=""

# BAND_POLICY_API_KEY: API Key for the Policy Guard Agent
BAND_POLICY_API_KEY=""

# BAND_POLICY_HANDLE: Handle/alias of the Policy Guard Agent
BAND_POLICY_HANDLE=""

# BAND_CORE_NAV_AGENT_ID: ID of the Core Navigator Agent
BAND_CORE_NAV_AGENT_ID=""

# BAND_CORE_NAV_API_KEY: API Key for the Core Navigator Agent
BAND_CORE_NAV_API_KEY=""

# BAND_CORE_NAV_HANDLE: Handle/alias of the Core Navigator Agent
BAND_CORE_NAV_HANDLE=""

# BAND_COMPLIANCE_DIR_AGENT_ID: ID of the Compliance Review Director Agent
BAND_COMPLIANCE_DIR_AGENT_ID=""

# BAND_COMPLIANCE_DIR_API_KEY: API Key for the Compliance Review Director Agent
BAND_COMPLIANCE_DIR_API_KEY=""

# BAND_COMPLIANCE_DIR_HANDLE: Handle/alias of the Compliance Review Director Agent
BAND_COMPLIANCE_DIR_HANDLE=""

# BAND_HR_ADVISORY_AGENT_ID: ID of the HR Advisory Agent
BAND_HR_ADVISORY_AGENT_ID=""

# BAND_HR_ADVISORY_API_KEY: API Key for the HR Advisory Agent
BAND_HR_ADVISORY_API_KEY=""

# BAND_HR_ADVISORY_HANDLE: Handle/alias of the HR Advisory Agent
BAND_HR_ADVISORY_HANDLE=""
