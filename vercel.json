{
  "buildCommand": "vite build && npx esbuild server.ts --bundle --platform=node --target=node18 --format=esm --packages=external --outfile=api/server.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
